DRIVE_FOLDER_NAME=Cube ACR

# Worker
CHECK_INTERVAL_SECONDS=300
PROCESSED_LOG_FILE=/home/processed.json
TEMP_DIR=/tmp
PORT=8080
HOST=0.0.0.0
