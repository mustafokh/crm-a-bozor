# Railway Variables — shu kalitlarni qo'shing

DATABASE_URL=${{Postgres.DATABASE_URL}}
JWT_SECRET=openssl_rand_base64_32
CRM_API_KEY=openssl_rand_base64_32
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
NODE_ENV=production
SEED_DB=false

# Cube ACR Drive sync (inside CRM — laptop off)
ACR_SYNC_ENABLED=true
ACR_CHECK_INTERVAL_MS=300000
DRIVE_FOLDER_NAME=Cube ACR
WHISPER_LANGUAGE=en
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
