# cp .env.example .env

# PostgreSQL (lokal: Docker yoki Neon; Railway: avtomatik ulanadi)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mkus_crm?schema=public"

# Auth
JWT_SECRET="change-me-to-long-random-secret"
SESSION_MAX_AGE=604800

# POST /api/calls uchun (X-API-Key header)
CRM_API_KEY="change-me-api-key"

NODE_ENV=development
PORT=3000
