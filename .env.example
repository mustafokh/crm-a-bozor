# cp .env.example .env

# PostgreSQL (lokal: Docker yoki Neon; Railway: avtomatik ulanadi)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mkus_crm?schema=public"

# Auth — productionda openssl rand -base64 32 bilan almashtiring
JWT_SECRET="change-me-to-long-random-secret-min-32-chars"
SESSION_MAX_AGE=604800

# POST /api/calls uchun (X-API-Key header) — kamida 24 belgi
CRM_API_KEY="change-me-api-key-min-24-chars"

# OpenAI — transkript AI tahlili (POST /api/calls)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

NODE_ENV=development
PORT=3000
