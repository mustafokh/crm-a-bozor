# CRM
CRM_API_URL=https://mkus-crm-fed7cd.azurewebsites.net
CRM_API_KEY=your-crm-api-key

# Service auth (CRM → this app). Defaults to CRM_API_KEY if empty.
SERVICE_API_KEY=

# Optional: migrate old flat AUTH_DIR/creds.json into this employee folder on boot
# LEGACY_SESSION_EMPLOYEE_ID=
# LEGACY_SESSION_EMPLOYEE_NAME=

# Multi-session storage (Azure: /home is persistent)
AUTH_DIR=/home/auth_info
SESSIONS_FILE=/home/sessions.json
MAX_SESSIONS=10

# HTTP
PORT=8080
HOST=0.0.0.0

IGNORE_GROUPS=true
TEXT_ONLY=false
