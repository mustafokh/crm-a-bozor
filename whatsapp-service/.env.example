# CRM
CRM_API_URL=https://mkus-crm-fed7cd.azurewebsites.net
CRM_API_KEY=your-crm-api-key

# WhatsApp session (Railway Volume / Azure persistent disk path)
AUTH_DIR=./auth_info

# HTTP (QR + health)
PORT=8080
HOST=0.0.0.0

# Optional: ignore messages from groups
IGNORE_GROUPS=true

# Optional: only forward text messages (skip stickers/media without caption)
TEXT_ONLY=false
